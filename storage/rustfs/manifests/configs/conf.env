RUSTFS_ADDRESS=:9000
RUSTFS_CONSOLE_ADDRESS=:9001
RUSTFS_CONSOLE_ENABLE=true
RUSTFS_OBS_ENVIRONMENT=development
RUSTFS_OBS_LOG_DIRECTORY=/logs
RUSTFS_OBS_LOGGER_LEVEL=warning 
RUSTFS_VOLUMES=http://rustfs-{0...4}.rustfs-headless.rustfs.svc.cluster.local:9000/data/rustfs0 http://rustfs-{0...4}.rustfs-headless.rustfs.svc.cluster.local:9000/data/rustfs1
RUSTFS_OBJECT_CACHE_ENABLE=true
